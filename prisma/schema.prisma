// RODINA Hotel & SPA - Prisma Schema
// PostgreSQL database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Admin Settings ============
// Stores hotel settings as key-value pairs (one row per section)
// Sections: hotel, currency, rooms, social, contact, images, content

model AdminSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("admin_settings")
}

// ============ Admin Sessions ============
// Stores active admin login sessions with expiry

model AdminSession {
  id      String   @id @default(cuid())
  token   String   @unique
  expires DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_sessions")
}

// ============ Admin Password ============
// Stores the hashed admin password (SHA-256)

model AdminPassword {
  id   String @id @default(cuid())
  hash String

  @@map("admin_passwords")
}
