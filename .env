# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
#   Local:     postgresql://postgres:postgres@localhost:5432/rodina_hotel
#   Supabase:  postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#   Neon:      postgresql://[USER]:[PASSWORD]@[ENDPOINT]/[DATABASE]?sslmode=require
#   Railway:   postgresql://postgres:[PASSWORD]@[HOST].railway.app:[PORT]/railway

DATABASE_URL=postgresql://z@localhost:5432/rodina_hotel
